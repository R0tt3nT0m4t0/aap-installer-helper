# Terraform state
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Variable files (may contain secrets)
*.tfvars
*.tfvars.json

# Plan files
*.tfplan

# Crash logs
crash.log
crash.*.log

# Cloud-Init sensitive overrides (keep cloud_init.cfg but ignore local variants)
cloud_init.local.cfg
cloud_init.*.cfg
!cloud_init.cfg

# SSH keys
*.pem
*.key
id_rsa*
id_ed25519*

# Editor
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# Logs
*.log